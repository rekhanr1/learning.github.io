DATABASE_URL="file:./dev.db"

# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional override; defaults to claude-sonnet-5 in src/lib/claude.ts
CLAUDE_MODEL=claude-sonnet-5

# Set to "true" to bypass the real Claude call and use canned steps instead,
# so you can test the upload -> parse -> review -> publish flow without an
# API key.
MOCK_CLAUDE=false
